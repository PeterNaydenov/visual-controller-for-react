{
  "name": "@peter.naydenov/visual-controller-for-react",
  "description": "Tool for building a micro-frontends(MFE) based on React component",
  "version": "3.1.0",
  "license": "MIT",
  "author": "Peter Naydenov",
  "type": "module",
  "main": "src/main.js",
  "module": "dist/visual-controller-for-react.esm.js",
  "types": "dist/main.d.ts",
  "unpkg": "dist/visual-controller-for-react.umd.js",
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=16.0.0"
  },
  "exports": {
    ".": {
      "import": "dist/visual-controller-for-react.esm.js",
      "require": "dist/visual-controller-for-react.cjs"
    }
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "scripts": {
    "build": "vite build && npm run types",
    "types": "tsc",
    "test": "vitest run",
    "cover": "vitest run --coverage"
  },
  "dependencies": {
    "ask-for-promise": "^3.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PeterNaydenov/visual-controller-for-react.git"
  },
  "homepage": "https://github.com/PeterNaydenov/visual-controller-for-react#readme",
  "bugs": {
    "url": "https://github.com/PeterNaydenov/visual-controller-for-react/issues"
  },
  "keywords": [
    "'micro",
    "frontend",
    "MFE",
    "react",
    "widgets",
    "visual",
    "controller'"
  ]
}
